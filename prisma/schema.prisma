// ─────────────────────────────────────────────
//  World Cup Tracker — Prisma Schema
//  Database: PostgreSQL (Neon)
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  googleId    String   @unique @map("google_id")
  email       String   @unique
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")

  roomsCreated Room[]       @relation("RoomCreator")
  memberships  RoomMember[]
  predictions  Prediction[]

  @@map("users")
}

// ─── Rooms (friend groups) ────────────────────

model Room {
  id         String   @id @default(uuid())
  name       String
  inviteCode String   @unique @map("invite_code")
  createdAt  DateTime @default(now()) @map("created_at")

  createdById String @map("created_by")
  createdBy   User   @relation("RoomCreator", fields: [createdById], references: [id])

  members     RoomMember[]
  predictions Prediction[]

  @@map("rooms")
}

// ─── Room membership + per-room leaderboard ───

model RoomMember {
  id       String   @id @default(uuid())
  score    Int      @default(0)
  joinedAt DateTime @default(now()) @map("joined_at")

  roomId String @map("room_id")
  userId String @map("user_id")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("room_members")
}

// ─── Matches (synced from football-data.org) ──

model Match {
  id         String      @id @default(uuid())
  externalId String      @unique @map("external_id")
  homeTeam   String      @map("home_team")
  awayTeam   String      @map("away_team")
  homeCrest  String?     @map("home_crest")
  awayCrest  String?     @map("away_crest")
  stage      String
  kickoffAt  DateTime    @map("kickoff_at")
  homeScore  Int?        @map("home_score")
  awayScore  Int?        @map("away_score")
  status     MatchStatus @default(SCHEDULED)
  updatedAt  DateTime    @updatedAt @map("updated_at")

  predictions Prediction[]

  @@map("matches")
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

// ─── Predictions (mini-game) ──────────────────

model Prediction {
  id             String   @id @default(uuid())
  predictedHome  Int      @map("predicted_home")
  predictedAway  Int      @map("predicted_away")
  pointsAwarded  Int?     @map("points_awarded")
  createdAt      DateTime @default(now()) @map("created_at")

  userId  String @map("user_id")
  matchId String @map("match_id")
  roomId  String @map("room_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  room  Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)

  // one prediction per user per match per room
  @@unique([userId, matchId, roomId])
  @@map("predictions")
}
